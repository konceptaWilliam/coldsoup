{
  "expo": {
    "name": "Coldsoup",
    "slug": "coldsoup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "coldsoup",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F6F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coldsoup.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F6F2"
      },
      "package": "com.coldsoup.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A1A18"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Coldsoup to access your photos to share images and set a profile picture.",
          "cameraPermission": "Allow Coldsoup to use the camera to take photos."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Coldsoup to record voice messages."
        }
      ],
      "expo-localization",
      "expo-video",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Coldsoup to use Face ID to unlock the app."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
